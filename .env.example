# Copy to `.env` in the project root (and optionally `src/.env` for keys you keep with library code).
# See Readme.md for setup.

# --- Schwab API (required for API calls) ---
APP_KEY=
APP_SECRET=

# --- Web UI ---
# Login password for NiceGUI
APP_PASSWORD=

# Long random string in production (signed user storage)
NICEGUI_STORAGE_SECRET=change-me-in-production

# Server port (default 8080)
NICEGUI_PORT=8080

# --- AI agent (set at least one provider you use) ---
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
